# LETSPACE - Environment Variables
# Copy this file to .env.local and fill in your values

# ─── DATABASE ────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/letspace"

# ─── AUTH ────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# ─── MPESA (Safaricom Daraja) ─────────────────
MPESA_CONSUMER_KEY="your-consumer-key"
MPESA_CONSUMER_SECRET="your-consumer-secret"
MPESA_PASSKEY="your-mpesa-passkey"
MPESA_SHORTCODE="174379"
MPESA_CALLBACK_URL="https://yourdomain.com/api/webhooks/mpesa"
MPESA_ENVIRONMENT="sandbox" # sandbox | production

# ─── STRIPE (International Billing) ──────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── CLAUDE AI ───────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── EMAIL (Resend) ───────────────────────────
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@letspace.co.ke"

# ─── SMS (Africa's Talking) ───────────────────
AT_API_KEY="your-africastalking-key"
AT_USERNAME="sandbox" # sandbox | your-username
AT_SENDER_ID="LETSPACE"

# ─── FILE STORAGE ─────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── REDIS (Caching & Queues) ─────────────────
REDIS_URL="redis://localhost:6379"

# ─── APP CONFIG ───────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LETSPACE"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
